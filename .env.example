# Copy to .env.local and fill in real values. .env.local is gitignored — never commit secrets.

# ── AI inference (Groq) ──────────────────────────────────────────────
# Required: the game's AI features call Groq's OpenAI-compatible API.
GROQ_API_KEY=

# Two-brain architecture (src/app/api/chat/route.ts). Both optional — defaults to
# the scout-17b model below if unset.
#   NARRATIVE_MODEL  → "the storyteller" (streams prose). Prose-grade model.
#   EXTRACTION_MODEL → "the rules engine" (emits state JSON). Cheap/fast is fine.
# qwen* narrative models get reasoning_effort:'none' automatically so they don't
# stream <think> tags into the prose.
NARRATIVE_MODEL=qwen/qwen3.6-27b
EXTRACTION_MODEL=meta-llama/llama-4-scout-17b-16e-instruct

# Optional local-model override for development (OpenAI-compatible endpoint, e.g. Ollama).
# When OLLAMA_BASE_URL is set, both calls route here instead of Groq.
OLLAMA_BASE_URL=
OLLAMA_MODEL=hf.co/FormatC/Qwen3-4B-DND:F16

# ── Supabase (auth, rate limiting, energy, cloud saves, memories) ─────
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# ── Admin / billing ──────────────────────────────────────────────────
ADMIN_EMAIL=
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
STRIPE_MONTHLY_PRICE_ID=
STRIPE_YEARLY_PRICE_ID=
